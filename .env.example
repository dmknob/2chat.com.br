# =============================================================================
# 2chat.com.br — Variáveis de Ambiente
# Copie para .env e preencha os valores. NUNCA versione o .env.
# =============================================================================

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development         # production em VPS
PORT=3000
BASE_URL=http://localhost:3000  # https://2chat.com.br em produção

# ─── Banco de Dados ───────────────────────────────────────────────────────────
DB_FILE=2chat_dev.db         # 2chat.db em produção

# ─── Analytics ────────────────────────────────────────────────────────────────
GA_ID=G-XXXXXXXXXX           # Google Analytics Measurement ID (opcional)

# ─── Cloudflare — KV Sync (publishTenantToKV) ─────────────────────────────────
# Gerado em: dash.cloudflare.com/profile/api-tokens
# Permissão necessária: Account > Workers KV Storage > Edit
CF_API_TOKEN=
CF_ACCOUNT_ID=f4a1d49a3508607cd86b7f8bbf956a55
KV_TENANTS_NAMESPACE_ID=c3e1daa6cec446b5bc6c2b58353abc16

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error
MORGAN_FORMAT=combined       # combined | dev | short
