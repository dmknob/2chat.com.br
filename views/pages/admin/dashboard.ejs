<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../../partials/head', { title, description, canonical, ogTitle: title, ogDesc: description }) %>
</head>
<body class="bg-[#0a0a0a] text-gray-200 min-h-screen flex flex-col">
  
  <header class="border-b border-gray-800 bg-black sticky top-0 z-10 w-full px-6 py-4 flex justify-between items-center">
    <div class="text-xl font-extrabold text-white">
      2chat<span class="text-blue-500">.</span> <span class="text-gray-500 text-sm ml-2 font-medium">Admin Hub</span>
    </div>
    <div>
        <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300 transition-colors">Sair</a>
    </div>
  </header>

  <main class="flex-1 w-full max-w-6xl mx-auto p-6 space-y-8">
    
    <!-- Top Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-gray-900 border border-gray-800 p-6 rounded-2xl">
        <h3 class="text-gray-400 text-sm font-medium mb-1">Parceiros Ativos</h3>
        <p class="text-3xl font-bold text-white"><%= parceirosCount %></p>
      </div>
      <div class="bg-gray-900 border border-gray-800 p-6 rounded-2xl">
        <h3 class="text-gray-400 text-sm font-medium mb-1">Total de Leads</h3>
        <p class="text-3xl font-bold text-blue-400"><%= leadsCount %></p>
      </div>
      <a href="/admin/waitlist" class="bg-gray-900 border border-gray-800 p-6 rounded-2xl hover:border-blue-500/50 transition-all group">
        <h3 class="text-gray-400 text-sm font-medium mb-1 group-hover:text-blue-400 transition-colors">Inscritos Beta</h3>
        <div class="flex items-center justify-between">
            <p class="text-3xl font-bold text-white"><%= waitlistCount %></p>
            <span class="text-blue-500 opacity-0 group-hover:opacity-100 transition-all">Ver lista →</span>
        </div>
      </a>
      <div class="bg-gray-900 border border-gray-800 p-6 rounded-2xl flex flex-col justify-center items-center">
          <a href="/admin/parceiros/new"
             class="bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm py-3 px-4 rounded-xl transition-all w-full text-center">
            + Novo Parceiro
          </a>
      </div>
    </div>

    <!-- Leads Table -->
    <div class="bg-gray-900 border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
      <div class="p-6 border-b border-gray-800 flex justify-between items-center">
        <h2 class="text-lg font-bold text-white">Últimos Leads Registrados</h2>
        <!-- Future Filter Placeholders -->
      </div>
      <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black/50 text-gray-500 text-xs uppercase tracking-wider">
              <th class="p-4 font-medium">Data</th>
              <th class="p-4 font-medium">Parceiro</th>
              <th class="p-4 font-medium">Origem</th>
              <th class="p-4 font-medium">Payload (Raw)</th>
              <th class="p-4 font-medium text-right">Origem Sys</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-gray-800">
            <% if (recentLeads.length === 0) { %>
              <tr>
                <td colspan="5" class="p-8 text-center text-gray-500">Nenhum lead capturado ainda.</td>
              </tr>
            <% } else { %>
              <% recentLeads.forEach(lead => { %>
                <tr class="hover:bg-gray-800/50 transition-colors group">
                  <td class="p-4 text-gray-300 whitespace-nowrap">
                    <%= new Date(lead.created_at).toLocaleString('pt-BR') %>
                  </td>
                  <td class="p-4 font-medium text-white">
                    <%= lead.parceiro_name || `ID ${lead.parceiro_id}` %>
                  </td>
                  <td class="p-4 text-gray-400 text-xs">
                    <% if (lead.city) { %>
                      <%= lead.city %>, <%= lead.region || '' %> <%= lead.country || '' %>
                    <% } else { %>
                      N/A
                    <% } %>
                  </td>
                  <td class="p-4 text-gray-400 font-mono text-xs truncate max-w-xs" title="<%= lead.payload_json %>">
                    <%= lead.payload_json %>
                  </td>
                  <td class="p-4 text-right text-xs text-gray-500">
                    <span class="bg-gray-800 px-2 py-1 rounded inline-block"><%= lead.source || 'api' %></span>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>
</html>
