<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../../partials/head', { title, description, canonical, ogTitle: title, ogDesc: description }) %>
</head>
<body class="bg-[#0a0a0a] text-gray-200 min-h-screen flex flex-col">
  
  <header class="border-b border-gray-800 bg-black sticky top-0 z-10 w-full px-6 py-4 flex justify-between items-center">
    <div class="flex items-center gap-4">
        <a href="/admin/hub" class="text-gray-500 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div class="text-xl font-extrabold text-white">
        2chat<span class="text-blue-500">.</span> <span class="text-gray-500 text-sm ml-2 font-medium">Waitlist Beta</span>
        </div>
    </div>
    <div>
        <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300 transition-colors">Sair</a>
    </div>
  </header>

  <main class="flex-1 w-full max-w-4xl mx-auto p-6 space-y-8">
    
    <div class="flex justify-between items-end">
        <div>
            <h1 class="text-2xl font-bold text-white mb-1">Interessados no Beta</h1>
            <p class="text-gray-400 text-sm">Lista de e-mails capturados via landing page</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 px-4 py-2 rounded-xl">
            <span class="text-gray-500 text-xs uppercase font-bold tracking-wider">Total</span>
            <p class="text-xl font-bold text-blue-400"><%= list.length %></p>
        </div>
    </div>

    <!-- Waitlist Table -->
    <div class="bg-gray-900 border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
      <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black/50 text-gray-500 text-xs uppercase tracking-wider">
              <th class="p-4 font-medium">Data de Cadastro</th>
              <th class="p-4 font-medium">E-mail</th>
              <th class="p-4 font-medium text-right">Ações</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-gray-800">
            <% if (list.length === 0) { %>
              <tr>
                <td colspan="3" class="p-8 text-center text-gray-500">Ninguém se inscreveu ainda.</td>
              </tr>
            <% } else { %>
              <% list.forEach(item => { %>
                <tr class="hover:bg-gray-800/50 transition-colors group">
                  <td class="p-4 text-gray-400 whitespace-nowrap">
                    <%= new Date(item.created_at).toLocaleString('pt-BR') %>
                  </td>
                  <td class="p-4 font-medium text-white">
                    <%= item.email %>
                  </td>
                  <td class="p-4 text-right">
                    <!-- Futuras ações: aprovar, remover, enviar warmup -->
                    <button class="text-gray-600 hover:text-blue-400 transition-colors opacity-0 group-hover:opacity-100" title="Copiar e-mail" onclick="navigator.clipboard.writeText('<%= item.email %>')">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>
</html>
