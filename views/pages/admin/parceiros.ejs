<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../../partials/head', { title, description, canonical, ogTitle: title, ogDesc: description }) %>
</head>
<body class="bg-[#0a0a0a] text-gray-200 min-h-screen flex flex-col">
  
  <header class="border-b border-gray-800 bg-black sticky top-0 z-10 w-full px-6 py-4 flex justify-between items-center">
    <div class="flex items-center gap-4">
        <a href="/admin/hub" class="text-gray-500 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div class="text-xl font-extrabold text-white">
        2chat<span class="text-blue-500">.</span> <span class="text-gray-500 text-sm ml-2 font-medium">Parceiros</span>
        </div>
    </div>
    <div>
        <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300 transition-colors">Sair</a>
    </div>
  </header>

  <main class="flex-1 w-full max-w-5xl mx-auto p-6 space-y-8">
    
    <div class="flex justify-between items-end">
        <div>
            <h1 class="text-2xl font-bold text-white mb-1">Empresas Parceiras</h1>
            <p class="text-gray-400 text-sm">Gerenciamento global de inquilinos (Tenants)</p>
        </div>
        <div class="flex gap-4 items-center">
            <a href="/admin/parceiros/new" class="bg-blue-600 hover:bg-blue-500 text-white font-bold px-4 py-2 rounded-xl transition-all flex items-center gap-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                Novo Parceiro
            </a>
        </div>
    </div>

    <!-- Parceiros Table -->
    <div class="bg-gray-900 border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
      <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black/50 text-gray-500 text-xs uppercase tracking-wider">
              <th class="p-4 font-medium">Empresa</th>
              <th class="p-4 font-medium">WhatsApp Base</th>
              <th class="p-4 font-medium text-center">Formulários</th>
              <th class="p-4 font-medium text-center">Status</th>
              <th class="p-4 font-medium text-right">Ações</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-gray-800">
            <% if (list.length === 0) { %>
              <tr>
                <td colspan="5" class="p-8 text-center text-gray-500">Nenhum parceiro cadastrado ainda.</td>
              </tr>
            <% } else { %>
              <% list.forEach(item => { %>
                <tr class="hover:bg-gray-800/50 transition-colors group">
                  <td class="p-4">
                    <div class="font-bold text-white"><%= item.name %></div>
                    <div class="text-xs text-gray-500 font-mono"><%= item.slug %></div>
                  </td>
                  <td class="p-4 font-medium text-gray-300">
                    <%= item.whatsapp %>
                  </td>
                  <td class="p-4 text-center">
                    <span class="bg-gray-800 text-gray-300 px-2 py-1 rounded-md text-xs font-bold border border-gray-700">
                        <%= item.forms_count %> link(s)
                    </span>
                  </td>
                  <td class="p-4 text-center">
                    <% if (item.is_active) { %>
                        <span class="inline-flex h-2 w-2 rounded-full bg-green-500" title="Ativo"></span>
                    <% } else { %>
                        <span class="inline-flex h-2 w-2 rounded-full bg-red-500" title="Inativo"></span>
                    <% } %>
                  </td>
                  <td class="p-4 text-right space-x-2">
                    <form action="/admin/parceiros/<%= item.slug %>/sync" method="POST" class="inline-block">
                        <button class="text-gray-500 hover:text-green-400 transition-colors" title="Forçar Sincronia KV (Edge)" onclick="return confirm('Sincronizar forçadamente com a Cloudflare?')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 21v-5h5"/></svg>
                        </button>
                    </form>
                    <a href="/admin/parceiros/<%= item.id %>" class="text-blue-500 hover:text-blue-400 transition-colors font-medium inline-block ml-4">
                        Gerenciar
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>
</html>
