{
  "name": "2chat",
  "version": "1.0.0",
  "description": "2chat.com.br — Conversion Gatekeeper",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch",
    "db:setup": "node database/setup-db.js",
    "db:seed": "node scripts/seed-zebra-box.js",
    "db:dump": "node scripts/dump-db.js",
    "db:restore": "node scripts/restore-db.js",
    "kv:sync": "node scripts/sync-kv.js",
    "kv:drain": "node scripts/drain-kv.js",
    "worker:deploy": "cd worker && npx wrangler deploy",
    "worker:dev": "cd worker && npx wrangler dev worker.js --local-upstream http://localhost:3010"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.0",
    "helmet": "^7.2.0",
    "morgan": "^1.10.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  },
  "author": "Corpo Digital",
  "license": "ISC"
}
